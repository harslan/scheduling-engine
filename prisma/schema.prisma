generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                      String                      @id @default(cuid())
  name                    String
  shortName               String
  slug                    String                      @unique
  timezone                String                      @default("America/New_York")
  appDisplayName          String                      @default("")
  logoUrl                 String?
  primaryColor            String                      @default("#0B7DE6")
  messageBoardHtml        String                      @default("")
  allowsRoomSelection     Boolean                     @default(true)
  allowsMultiDayEvents    Boolean                     @default(true)
  allowsRoomlessEvents    Boolean                     @default(false)
  allowsUnregisteredUsers Boolean                     @default(false)
  calendarIsPrivate       Boolean                     @default(false)
  requiresApproval        Boolean                     @default(false)
  allowsEventChanges      Boolean                     @default(true)
  allowsRoomRequests      Boolean                     @default(false)
  collectsEventTitle      Boolean                     @default(true)
  collectsAttendeeCount   Boolean                     @default(true)
  collectsContactPhone    Boolean                     @default(false)
  roomOpeningTime         String                      @default("07:00")
  roomClosingTime         String                      @default("22:00")
  maxEventLengthMinutes   Int                         @default(480)
  schedulingCutoffDays    Int?
  eventSingularTerm       String                      @default("Event")
  eventPluralTerm         String                      @default("Events")
  roomTerm                String                      @default("Room")
  emailReplyToAddress     String                      @default("")

  // Reserve Interactive (Infor SCS) integration
  reserveEnabled              Boolean                     @default(false)
  reserveExportEnabled        Boolean                     @default(false)
  reserveImportMode           String?                     // null=off, "manual", "automatic"
  reserveGatewayUsername      String                      @default("")
  reserveGatewayPassword      String                      @default("")
  reserveWebhookSecret        String                      @default("")
  reserveSiteName             String                      @default("")
  reserveEventIdFieldName     String                      @default("")
  reserveEventNotesFieldName  String                      @default("")
  reserveEventOrgFieldName    String                      @default("")
  reserveOwnerUsername        String                      @default("")
  reserveSalespersonUsername  String                      @default("")
  reserveLifecycleStage      String                      @default("")
  reserveHoldFunctionType    String                      @default("")
  reserveHoldContactId       String                      @default("")
  reserveLastSyncAt          DateTime?
  reserveLastExportAt        DateTime?
  reserveLastImportAt        DateTime?

  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  contentPages            ContentPage[]
  eventOrganizations      EventOrganization[]
  eventTypes              EventType[]
  events                  Event[]
  calendarViews           OrganizationCalendarView[]
  emailTemplates          OrganizationEmailTemplate[]
  members                 OrganizationMember[]
  roomConfigurationTypes  RoomConfigurationType[]
  rooms                   Room[]
  reserveAccounts         ReserveAccount[]
  reserveContacts         ReserveContact[]
  reserveEvents           ReserveEvent[]
  reserveWebhookEvents    ReserveWebhookEvent[]
  reserveSyncLogs         ReserveSyncLog[]

  @@map("organizations")
}

model User {
  id              String               @id @default(cuid())
  email           String               @unique
  name            String               @default("")
  passwordHash    String?
  active          Boolean              @default(true)
  isSystemAdmin   Boolean              @default(false)
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  accounts        Account[]
  approvalActions ApprovalAction[]
  submittedEvents Event[]              @relation("SubmittedBy")
  memberships     OrganizationMember[]
  sessions        Session[]

  @@map("users")
}

model OrganizationMember {
  organizationId String
  userId         String
  role           OrgRole      @default(USER)
  calendarSecret String       @default("")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([organizationId, userId])
  @@map("organization_members")
}

model Room {
  id                   String              @id @default(cuid())
  organizationId       String
  name                 String
  slug                 String
  iconText             String              @default("")
  notes                String              @default("")
  active               Boolean             @default(true)
  managersOnly         Boolean             @default(false)
  sortOrder            Int                 @default(0)
  concurrentEventLimit Int                 @default(1)
  parentRoomId         String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  bufferMinutes        Int                 @default(0)
  capacity             Int?
  reserveLocationName  String              @default("")
  events               Event[]
  configurations       RoomConfiguration[]
  organization         Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentRoom           Room?               @relation("RoomHierarchy", fields: [parentRoomId], references: [id])
  childRooms           Room[]              @relation("RoomHierarchy")

  @@unique([organizationId, slug])
  @@map("rooms")
}

model RoomConfiguration {
  id                   String                 @id @default(cuid())
  roomId               String
  name                 String
  configurationTypeId  String?
  concurrentEventLimit Int                    @default(1)
  imageUrl             String?
  events               Event[]
  configurationType    RoomConfigurationType? @relation(fields: [configurationTypeId], references: [id])
  room                 Room                   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("room_configurations")
}

model RoomConfigurationType {
  id                String              @id @default(cuid())
  organizationId    String
  name              String
  imageUrl          String?
  reserveSetupStyle String              @default("")
  events            Event[]
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  configurations    RoomConfiguration[]

  @@map("room_configuration_types")
}

model EventType {
  id                  String       @id @default(cuid())
  organizationId      String
  name                String
  colorIndex          Int?
  iconTextOverride    String       @default("")
  reserveFunctionType String       @default("")
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events              Event[]

  @@map("event_types")
}

model Event {
  id                      String                 @id @default(cuid())
  organizationId          String
  roomId                  String?
  roomConfigurationId     String?
  roomConfigurationTypeId String?
  eventTypeId             String?
  submitterId             String?
  title                   String                 @default("")
  description             String                 @default("")
  websiteUrl              String                 @default("")
  notes                   String                 @default("")
  contactName             String                 @default("")
  contactEmail            String                 @default("")
  contactPhone            String                 @default("")
  eventOrganization       String                 @default("")
  startDateTime           DateTime?
  endDateTime             DateTime?
  allDay                  Boolean                @default(false)
  expectedAttendeeCount   Int?
  recurrenceRule          String?
  recurrenceEndDate       DateTime?
  status                  EventStatus            @default(PENDING)
  approved                Boolean                @default(false)
  published               Boolean                @default(true)
  deleted                 Boolean                @default(false)
  isExternal              Boolean                @default(false)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  approvalActions         ApprovalAction[]
  activityLog             EventActivity[]
  instances               EventInstance[]
  eventType               EventType?             @relation(fields: [eventTypeId], references: [id])
  organization            Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roomConfiguration       RoomConfiguration?     @relation(fields: [roomConfigurationId], references: [id])
  roomConfigurationType   RoomConfigurationType? @relation(fields: [roomConfigurationTypeId], references: [id])
  room                    Room?                  @relation(fields: [roomId], references: [id])
  submitter               User?                  @relation("SubmittedBy", fields: [submitterId], references: [id])
  excludedDates           ExcludedDate[]
  reserveEvents           ReserveEvent[]

  @@index([organizationId, startDateTime])
  @@index([organizationId, roomId])
  @@map("events")
}

model EventInstance {
  id                      String   @id @default(cuid())
  eventId                 String
  startDateTime           DateTime
  endDateTime             DateTime
  roomConfigurationId     String?
  roomConfigurationTypeId String?
  eventTypeId             String?
  expectedAttendeeCount   Int?
  deleted                 Boolean  @default(false)
  event                   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_instances")
}

model ExcludedDate {
  id      String   @id @default(cuid())
  eventId String
  date    DateTime @db.Date
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, date])
  @@map("excluded_dates")
}

model ApprovalAction {
  id        String             @id @default(cuid())
  eventId   String
  userId    String
  action    ApprovalActionType
  comment   String             @default("")
  createdAt DateTime           @default(now())
  event     Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id])

  @@map("approval_actions")
}

model EventActivity {
  id         String   @id @default(cuid())
  eventId    String
  action     String
  details    Json?
  actorEmail String?
  createdAt  DateTime @default(now())
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_activities")
}

model EmailTemplate {
  id            String                      @id @default(cuid())
  slug          String                      @unique
  name          String
  organizations OrganizationEmailTemplate[]

  @@map("email_templates")
}

model OrganizationEmailTemplate {
  organizationId  String
  emailTemplateId String
  subject         String        @default("")
  bodyHtml        String        @default("")
  active          Boolean       @default(true)
  emailTemplate   EmailTemplate @relation(fields: [emailTemplateId], references: [id], onDelete: Cascade)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([organizationId, emailTemplateId])
  @@map("organization_email_templates")
}

model ContentPage {
  id             String       @id @default(cuid())
  organizationId String
  slug           String
  title          String
  bodyHtml       String       @default("")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@map("content_pages")
}

model EventOrganization {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  isExternal     Boolean      @default(false)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@map("event_organizations")
}

model OrganizationCalendarView {
  id             String           @id @default(cuid())
  organizationId String
  viewType       CalendarViewType
  showRoomIcons  Boolean          @default(true)
  enabled        Boolean          @default(true)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, viewType])
  @@map("organization_calendar_views")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ReserveAccount {
  id              String       @id @default(cuid())
  organizationId  String
  reserveUniqueId String
  name            String       @default("")
  reserveData     Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, reserveUniqueId])
  @@map("reserve_accounts")
}

model ReserveContact {
  id              String       @id @default(cuid())
  organizationId  String
  reserveUniqueId String
  name            String       @default("")
  accountName     String       @default("")
  reserveData     Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, reserveUniqueId])
  @@map("reserve_contacts")
}

model ReserveEvent {
  id              String       @id @default(cuid())
  organizationId  String
  reserveUniqueId String
  eventId         String?
  generalData     Json?
  importData      Json?
  importDataUpdatedAt DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event           Event?       @relation(fields: [eventId], references: [id])

  @@unique([organizationId, reserveUniqueId])
  @@index([organizationId, eventId])
  @@map("reserve_events")
}

model ReserveWebhookEvent {
  id              String       @id @default(cuid())
  organizationId  String
  reserveUniqueId String       @default("")
  action          String
  receivedAt      DateTime     @default(now())
  processedAt     DateTime?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, processedAt])
  @@map("reserve_webhook_events")
}

model ReserveSyncLog {
  id             String       @id @default(cuid())
  organizationId String
  direction      String       // "export" or "import"
  status         String       // "success", "error", "partial"
  summary        Json?
  eventsProcessed Int         @default(0)
  errorMessage   String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@map("reserve_sync_logs")
}

enum OrgRole {
  ADMIN
  MANAGER
  EVENT_SUPPORT
  USER
}

enum EventStatus {
  DRAFT
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

enum ApprovalActionType {
  SUBMITTED
  APPROVED
  DENIED
  CHANGED
  REMINDER_SENT
}

enum CalendarViewType {
  YEAR
  MONTH
  WEEK
  DAY
}
